{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
"include": [
  "backend/**/*.ts",
  "frontend/**/*.ts",
  "frontend/**/*.tsx"
],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build"
  ]
}
